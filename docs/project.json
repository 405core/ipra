{
  "name": "docs",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "docs",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitepress dev docs --host 0.0.0.0 --port 4400"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.vitepress/dist"],
      "options": {
        "command": "pnpm exec vitepress build docs"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitepress preview docs --host 0.0.0.0 --port 4401"
      }
    }
  }
}

