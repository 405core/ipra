AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=9000

# Main HumanOmni-0.5B checkpoint downloaded from ModelScope.
HUMANOMNI_MODEL_PATH=../../models/humanomni0.5/iic/HumanOmni-0___5B

# Hugging Face cache used for SigLIP, Whisper, and BERT dependency models.
HF_HOME=../../models/humanomni0.5/huggingface

# Keep inference fully local after SigLIP, Whisper, and BERT are available in HF_HOME.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Set to 1 when diagnosing model-loading details.
AI_SERVICE_VERBOSE_WARNINGS=0

# Optional: override visible CUDA devices.
CUDA_VISIBLE_DEVICES=0

# HumanOmni window upload API.
HUMANOMNI_UPLOAD_DIR=uploads/humanomni-windows
HUMANOMNI_UPLOAD_MAX_MB=200
HUMANOMNI_INFER_TIMEOUT_SECONDS=900

# Business LLM. The current development build supports mock mode first.
BUSINESS_LLM_PROVIDER=mock
BUSINESS_LLM_BASE_URL=
BUSINESS_LLM_API_KEY=
BUSINESS_LLM_MODEL=mock-business-llm
BUSINESS_LLM_TIMEOUT_SECONDS=120

# Local Ollama example:
# BUSINESS_LLM_PROVIDER=ollama
# BUSINESS_LLM_BASE_URL=http://127.0.0.1:11434
# BUSINESS_LLM_MODEL=qwen3.5:4b

# Reserved for later ASR integration. ASR is owned by another module; AI-Service
# only keeps optional request fields so it can be merged later.
ASR_PROVIDER=
ASR_MODEL_PATH=
