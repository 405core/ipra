AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=9000
AI_SERVICE_CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:4300,http://127.0.0.1:4300

# Main HumanOmni-0.5B checkpoint downloaded from ModelScope.
HUMANOMNI_MODEL_PATH=../../models/humanomni0.5/iic/HumanOmni-0___5B

# Hugging Face cache used for SigLIP, Whisper, and BERT dependency models.
HF_HOME=../../models/humanomni0.5/huggingface

# Keep inference fully local after SigLIP, Whisper, and BERT are available in HF_HOME.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Set to 1 when diagnosing model-loading details.
AI_SERVICE_VERBOSE_WARNINGS=0

# Optional: override visible CUDA devices.
CUDA_VISIBLE_DEVICES=0

# HumanOmni window upload API.
HUMANOMNI_UPLOAD_DIR=uploads/humanomni-windows
HUMANOMNI_UPLOAD_MAX_MB=200
HUMANOMNI_INFER_TIMEOUT_SECONDS=900

# Business LLM. The default runs the local Qwen2.5-3B-Instruct model
# downloaded from ModelScope. Use mock only for schema-only tests.
BUSINESS_LLM_PROVIDER=transformers_local
BUSINESS_LLM_MODEL=Qwen2.5-3B-Instruct
BUSINESS_LLM_MODEL_PATH=../../models/business-llm/modelscope/Qwen2.5-3B-Instruct
BUSINESS_LLM_TIMEOUT_SECONDS=300
BUSINESS_LLM_MAX_NEW_TOKENS=768
BUSINESS_LLM_TORCH_DTYPE=auto
BUSINESS_LLM_DEVICE_MAP=auto

# OpenAI-compatible server example for DeepSeek V3.2 full precision deployments
# served by vLLM, SGLang, TGI, or another compatible gateway.
# BUSINESS_LLM_PROVIDER=openai_compatible
# BUSINESS_LLM_MODEL=deepseek-ai/DeepSeek-V3.2
# BUSINESS_LLM_BASE_URL=http://deepseek-server:8000/v1
# BUSINESS_LLM_API_KEY=local-or-internal-token
# BUSINESS_LLM_TIMEOUT_SECONDS=900
# BUSINESS_LLM_MAX_NEW_TOKENS=1536
# BUSINESS_LLM_TEMPERATURE=1.0
# BUSINESS_LLM_TOP_P=0.95

# Mock example:
# BUSINESS_LLM_PROVIDER=mock
# BUSINESS_LLM_MODEL=mock-business-llm

# Iflytek realtime ASR large model. Keep real values only in .env.local.
IFLYTEK_RTASR_APP_ID=
IFLYTEK_RTASR_API_KEY=
IFLYTEK_RTASR_API_SECRET=
IFLYTEK_RTASR_URL=wss://office-api-ast-dx.iflyaisol.com/ast/communicate/v1
IFLYTEK_RTASR_LANGUAGE=autodialect
